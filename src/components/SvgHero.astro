---
import fs from "node:fs";
import path from "node:path";

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const svgPath = path.join(process.cwd(), "public", "heroes", `${slug}.svg`);
let svgContent = "";

try {
  svgContent = fs.readFileSync(svgPath, "utf-8");
} catch {
  // no SVG for this project
}
---

{svgContent && <div class="svg-hero" set:html={svgContent} />}

<style>
  .svg-hero {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .svg-hero :global(svg) {
    width: 100%;
    height: 100%;
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 0.35;
      transform: scale(1);
    }
    50% {
      opacity: 0.9;
      transform: scale(1.15);
    }
  }

  .svg-hero :global(path) {
    fill: var(--color-accent);
    transform-origin: center;
    transform-box: fill-box;
    will-change: transform, opacity;
    animation: pulse calc(4s + var(--i, 0) * 0.2s) ease-in-out infinite;
    animation-delay: calc(var(--i, 0) * -0.4s);
  }

  @media (prefers-reduced-motion: reduce) {
    .svg-hero :global(path) {
      animation: none;
      opacity: 0.6;
    }
  }
</style>
