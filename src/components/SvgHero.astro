---
import fs from "node:fs";
import path from "node:path";
import SvgHeroInteractive from "./SvgHeroInteractive.svelte";

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const svgPath = path.join(process.cwd(), "public", "heroes", `${slug}.svg`);
let svgContent = "";

try {
  svgContent = fs.readFileSync(svgPath, "utf-8");
} catch {
  // no SVG for this project
}
---

{svgContent && (
  <div class="svg-hero-wrapper">
    <div class="svg-hero-static" set:html={svgContent} />
    <SvgHeroInteractive client:load svg={svgContent} />
  </div>
)}

<style>
  .svg-hero-wrapper {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .svg-hero-static {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .svg-hero-static :global(svg) {
    width: 100%;
    height: 100%;
  }

  .svg-hero-static :global(path) {
    fill: var(--color-accent);
    opacity: 0.4;
  }
</style>
