---
import LissajousImage from "./LissajousImage.svelte";

interface Props {
  title: string;
  description: string;
  slug: string;
}

const { title, description, slug } = Astro.props;
---

<article class="project-card">
  <a href={`/projects/${slug}/`}>
    <div class="card-hero" style={`view-transition-name: hero-${slug}`}>
      <LissajousImage client:only="svelte" src={`/lissajous/${slug}.json`} />
    </div>
    <div class="card-body">
      <h3 class="card-title">{title}</h3>
      <p class="card-description">{description}</p>
    </div>
  </a>
</article>

<style>
  .project-card {
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: var(--color-surface);
    overflow: hidden;
    transition: box-shadow var(--transition-base), border-color var(--transition-base), opacity var(--transition-base);
    container-type: inline-size;
  }

  .project-card:hover {
    border-color: var(--color-accent);
    box-shadow: var(--glow-accent);
  }

  a {
    color: inherit;
    text-decoration: none;
    display: block;
  }

  .card-hero {
    overflow: hidden;
    aspect-ratio: 3 / 1;
  }

  .card-body {
    padding: var(--space-lg);
  }

  .card-title {
    font-family: var(--font-display);
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .card-description {
    color: var(--color-fg-muted);
    font-size: 0.9375rem;
  }

</style>
