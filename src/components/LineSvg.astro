---
import fs from "node:fs";
import path from "node:path";

interface Props {
  slug: string;
}

const { slug } = Astro.props;
const svgPath = path.join(process.cwd(), "public", "svg", `${slug}.svg`);
let svgContent = "";

try {
  svgContent = fs.readFileSync(svgPath, "utf-8");
} catch {
  // no SVG for this slug
}
---

{svgContent && <div class="line-svg" set:html={svgContent} />}

<style is:global>
  .line-svg {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .line-svg svg {
    width: 100%;
    height: 100%;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.35; }
    50% { opacity: 0.9; }
  }

  .line-svg path {
    fill: var(--color-accent);
    will-change: opacity;
    animation: pulse calc(4s + var(--i, 0) * 0.2s) ease-in-out infinite;
    animation-delay: calc(var(--i, 0) * -0.4s);
  }

  @media (prefers-reduced-motion: reduce) {
    .line-svg path {
      animation: none;
      opacity: 0.6;
    }
  }
</style>
