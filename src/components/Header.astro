---
const pathname = Astro.url.pathname;
---

<header class="site-header">
  <nav>
    <a href="/" class="site-logo" aria-label="Cybernetic Studio home">
      <img src="/favicon.svg" alt="" width="32" height="32" />
    </a>
    <ul>
      <li><a href="/" aria-current={pathname === "/" ? "page" : undefined}>Projects</a></li>
      <li><a href="/news/" aria-current={pathname.startsWith("/news") ? "page" : undefined}>News</a></li>
      <li><a href="/people/" aria-current={pathname.startsWith("/people") ? "page" : undefined}>People</a></li>
    </ul>
  </nav>
</header>

<style>
  .site-header {
    padding: var(--space-md) var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }

  nav {
    max-width: var(--width-wide);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  .site-logo img {
    display: block;
    width: 32px;
    height: 32px;
    border-radius: 4px;
  }

  ul {
    display: flex;
    list-style: none;
    gap: var(--space-lg);
  }

  a {
    color: var(--color-fg-muted);
    transition: color var(--transition-fast), text-shadow var(--transition-fast);
  }

  a:hover,
  a[aria-current="page"] {
    color: var(--color-fg);
    text-shadow: var(--glow-accent);
  }
</style>
