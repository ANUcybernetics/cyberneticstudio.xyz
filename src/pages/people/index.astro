---
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";
import ContentLayout from "astro-theme-anu/layouts/ContentLayout.astro";
import { siteConfig } from "../../site-config";

const people = (await getCollection("people")).toSorted(
  (a, b) => a.data.order - b.data.order,
);

const rendered = await Promise.all(
  people.map(async (person) => {
    const { Content } = await render(person);
    return { person, Content };
  }),
);
---

<ContentLayout
  title="People"
  description="The people behind Cybernetic Studio"
  {...siteConfig}
>
  <div class="people-grid">
    {rendered.map(({ person, Content }) => (
      <article class="person-card">
        {person.data.photo && (
          <Image
            src={person.data.photo}
            alt={person.data.photoAlt ?? person.data.name}
            width={240}
            class="person-photo"
          />
        )}
        <div class="person-info">
          <h2>{person.data.name}</h2>
          <p class="person-role">{person.data.role}</p>
          <div class="person-bio">
            <Content />
          </div>
        </div>
      </article>
    ))}
  </div>
</ContentLayout>

<style>
  .people-grid {
    display: grid;
    gap: 2rem;
  }

  .person-card {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: 2rem;
    align-items: start;
  }

  .person-photo {
    width: 100%;
    height: auto;
    border-radius: 8px;
  }

  .person-info h2 {
    margin: 0 0 0.25rem;
  }

  .person-role {
    font-weight: 600;
    margin: 0 0 1rem;
  }

  .person-bio :global(p:last-child) {
    margin-bottom: 0;
  }

  @media (width < 640px) {
    .person-card {
      grid-template-columns: 1fr;
    }
  }
</style>
