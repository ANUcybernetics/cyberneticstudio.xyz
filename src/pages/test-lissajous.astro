---
import BaseLayout from "../layouts/BaseLayout.astro";
import LissajousImage from "../components/LissajousImage.svelte";

const projects = [
  { slug: "panic", title: "Panic" },
  { slug: "llm-library", title: "LLM Library" },
  { slug: "llms-unplugged", title: "LLMs Unplugged" },
  { slug: "imaginative-restoration", title: "Imaginative Restoration" },
  { slug: "perceptron-apparatus", title: "Perceptron Apparatus" },
];
---

<BaseLayout title="Lissajous Image Test">
  <h1>Lissajous Image Test</h1>
  <p>Each panel resolves to its source image periodically (5-10s), then drifts back into abstract patterns.</p>
  <div class="grid">
    {projects.map((p) => (
      <div class="card">
        <div class="card-hero">
          <LissajousImage client:only="svelte" src={`/lissajous/${p.slug}.json`} />
        </div>
        <p>{p.title}</p>
      </div>
    ))}
  </div>
</BaseLayout>

<style>
  h1 {
    margin-bottom: var(--space-md);
  }

  p {
    margin-bottom: var(--space-lg);
    color: var(--color-fg-muted);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
    gap: var(--space-lg);
  }

  .card {
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    overflow: hidden;
    background: var(--color-surface);
  }

  .card-hero {
    aspect-ratio: 16 / 9;
  }

  .card p {
    padding: var(--space-md);
    color: var(--color-accent);
    margin: 0;
  }
</style>
