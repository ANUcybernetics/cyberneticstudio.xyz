---
import { getCollection } from "astro:content";
import BaseLayout from "astro-theme-anu/layouts/BaseLayout.astro";
import Card from "astro-theme-anu/components/Card.astro";
import CardGrid from "astro-theme-anu/components/CardGrid.astro";
import LissajousWave from "../components/LissajousWave.svelte";
import { siteConfig } from "../site-config";

const allProjects = (await getCollection("projects"))
  .filter((p) => p.data.layout !== "standalone")
  .toSorted((a, b) => a.data.order - b.data.order);

const allNews = (await getCollection("news"))
  .toSorted((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 6);
---

<BaseLayout
  title={siteConfig.name}
  description="A research-through-art studio at the ANU School of Cybernetics."
  {...siteConfig}
>
  <div class="home-hero">
    <LissajousWave client:only="svelte" />
    <h1>Cybernetic Studio</h1>
  </div>

  {allProjects.length > 0 && (
    <section class="home-section" aria-labelledby="projects-heading" id="projects">
      <h2 id="projects-heading">Projects</h2>
      <CardGrid columns={3}>
        {allProjects.map((project) => (
          <Card
            title={project.data.title}
            href={`/projects/${project.id}/`}
            image={project.data.hero}
            imageAlt={project.data.heroAlt}
          >
            {project.data.description}
          </Card>
        ))}
      </CardGrid>
    </section>
  )}

  {allNews.length > 0 && (
    <section class="home-section" aria-labelledby="news-heading" id="news">
      <h2 id="news-heading">News</h2>
      <CardGrid columns={3}>
        {allNews.map((post) => (
          <Card
            title={post.data.title}
            href={`/news/${post.id}/`}
            image={post.data.hero}
            imageAlt={post.data.heroAlt}
          >
            {post.data.description}
          </Card>
        ))}
      </CardGrid>
      <p class="news-more"><a href="/news/">All news &rarr;</a></p>
    </section>
  )}
</BaseLayout>

<style>
  .home-hero {
    position: relative;
    display: grid;
    place-items: center;
    width: 100%;
    min-height: clamp(240px, 32vw, 420px);
  }

  .home-hero :global(canvas) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .home-hero h1 {
    position: relative;
    margin: 0;
    font-size: clamp(2rem, 6vw, 4rem);
  }

  .home-section {
    margin-top: 3rem;
  }

  .home-section h2 {
    margin-bottom: 1.5rem;
  }

  .news-more {
    margin-top: 1.5rem;
    text-align: right;
  }
</style>
