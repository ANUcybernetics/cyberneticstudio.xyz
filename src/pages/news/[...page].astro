---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import ContentLayout from "astro-theme-anu/layouts/ContentLayout.astro";
import Card from "astro-theme-anu/components/Card.astro";
import CardGrid from "astro-theme-anu/components/CardGrid.astro";
import Pagination from "astro-theme-anu/components/Pagination.astro";
import { siteConfig } from "../../site-config";

export const getStaticPaths = (async ({ paginate }) => {
  const allNews = (await getCollection("news")).toSorted(
    (a, b) => b.data.date.getTime() - a.data.date.getTime(),
  );
  return paginate(allNews, { pageSize: 12 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<ContentLayout
  title="News"
  description="Latest news from Cybernetic Studio"
  {...siteConfig}
>
  <CardGrid columns={3}>
    {page.data.map((post) => (
      <Card
        title={post.data.title}
        href={`/news/${post.id}/`}
        image={post.data.hero}
        imageAlt={post.data.heroAlt}
        headingLevel="h2"
      >
        {post.data.description}
      </Card>
    ))}
  </CardGrid>

  {page.lastPage > 1 && <Pagination page={page} />}
</ContentLayout>
