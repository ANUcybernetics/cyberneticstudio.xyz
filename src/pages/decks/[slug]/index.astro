---
import DeckLayout from "../../../layouts/DeckLayout.astro";
import DeckLoader from "../../../components/DeckLoader.svelte";
import { parseDeckFrontmatter } from "../../../lib/deck-meta";
import fs from "node:fs";
import path from "node:path";

export function getStaticPaths() {
  const decksDir = path.resolve("src/decks");
  const entries = fs.readdirSync(decksDir, { withFileTypes: true });
  return entries
    .filter((e) => e.isDirectory() && fs.existsSync(path.join(decksDir, e.name, "slides.deck.svelte")))
    .map((e) => {
      const raw = fs.readFileSync(path.join(decksDir, e.name, "slides.deck.svelte"), "utf-8");
      const { data } = parseDeckFrontmatter(raw, e.name);
      return {
        params: { slug: e.name },
        props: { title: data.title ?? e.name, description: data.description, image: data.image },
      };
    });
}

const { slug } = Astro.params;
const { title, description, image } = Astro.props;
---

<DeckLayout title={title} description={description} image={image}>
  <DeckLoader slug={slug} client:only="svelte" />
</DeckLayout>
