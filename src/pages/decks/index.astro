---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { parseDeckFrontmatter } from "astromotion";
import fs from "node:fs";
import path from "node:path";

interface DeckEntry {
  slug: string;
  title: string;
  description?: string;
}

const decksDir = path.resolve("src/decks");
const decks: DeckEntry[] = [];

for (const entry of fs.readdirSync(decksDir, { withFileTypes: true })) {
  if (entry.isDirectory()) {
    const dirPath = path.join(decksDir, entry.name);
    for (const file of fs.readdirSync(dirPath)) {
      const match = file.match(/^(.+)\.deck\.md$/);
      if (!match) continue;
      const name = match[1];
      const raw = fs.readFileSync(path.join(dirPath, file), "utf-8");
      const { data } = parseDeckFrontmatter(raw, entry.name);
      const slug = name === "slides" ? entry.name : `${entry.name}/${name}`;
      decks.push({ slug, title: data.title ?? slug, description: data.description });
    }
  } else if (entry.isFile()) {
    const match = entry.name.match(/^(.+)\.deck\.md$/);
    if (!match) continue;
    const name = match[1];
    const raw = fs.readFileSync(path.join(decksDir, entry.name), "utf-8");
    const { data } = parseDeckFrontmatter(raw, name);
    decks.push({ slug: name, title: data.title ?? name, description: data.description });
  }
}

decks.sort((a, b) => a.slug.localeCompare(b.slug));
---

<BaseLayout title="Decks">
  <h1>Decks</h1>
  <ul>
    {decks.map((deck) => (
      <li>
        <a href={`/decks/${deck.slug}/`}>{deck.title}</a>
        {deck.description && <span> — {deck.description}</span>}
      </li>
    ))}
  </ul>
</BaseLayout>

<style>
  h1 {
    margin-bottom: 2rem;
  }

  ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  li span {
    opacity: 0.7;
  }
</style>
