---
import type { ImageMetadata } from "astro";
import ContentLayout from "astro-theme-anu/layouts/ContentLayout.astro";
import { siteConfig } from "../site-config";

interface Props {
  title: string;
  description: string;
  date: string;
  hero?: ImageMetadata;
  heroAlt?: string;
}

const { title, description, date, hero, heroAlt } = Astro.props;
const formattedDate = new Date(date).toLocaleDateString("en-AU", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<ContentLayout
  title={title}
  description={description}
  heroImage={hero}
  heroImageAlt={heroAlt ?? title}
  {...siteConfig}
>
  <p class="news-date">
    <time datetime={date}>{formattedDate}</time>
  </p>
  <slot />
</ContentLayout>

<style>
  .news-date {
    font-size: 0.9375rem;
    opacity: 0.75;
    margin: 0 0 1.5rem;
  }
</style>
