---
import DeckHead from "../components/DeckHead.astro";
import "../decks/deck-theme.css";

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const { title, description, image } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <DeckHead title={title} description={description} image={image} />
  </head>
  <body>
    <slot />
  </body>
</html>
