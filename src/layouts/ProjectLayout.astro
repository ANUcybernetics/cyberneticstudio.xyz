---
import { Image } from "astro:assets";
import BaseLayout from "./BaseLayout.astro";
import SvgHero from "../components/SvgHero.astro";

interface Publication {
  title: string;
  venue: string;
  date: string;
  url?: string;
}

interface Props {
  title: string;
  description: string;
  creators: string[];
  materials?: string;
  date: string;
  hero?: ImageMetadata;
  heroAlt?: string;
  slug?: string;
  github?: string;
  publications: Publication[];
  relatedProjects: { slug: string; title: string }[];
}

const {
  title,
  description,
  creators,
  materials,
  date,
  hero,
  heroAlt,
  slug,
  github,
  publications,
  relatedProjects,
} = Astro.props;

const formattedDate = new Date(date).toLocaleDateString("en-AU", {
  year: "numeric",
  month: "long",
});
---

<BaseLayout title={title} description={description} image={hero?.src}>
  <article class="project">
    {slug && (
      <div class="project-hero" style={slug ? `view-transition-name: hero-${slug}` : undefined}>
        <SvgHero slug={slug} />
        <h1 class="hero-title">{title}</h1>
      </div>
    )}
    <header class="project-header">
      {!slug && <h1>{title}</h1>}
      <dl class="project-meta">
        {creators.length > 0 && (
          <>
            <dt>Creators</dt>
            <dd>{creators.join(", ")}</dd>
          </>
        )}
        {materials && (
          <>
            <dt>Materials</dt>
            <dd>{materials}</dd>
          </>
        )}
        <dt>Launched</dt>
        <dd><time datetime={date}>{formattedDate}</time></dd>
        {github && (
          <>
            <dt>Source</dt>
            <dd><a href={github}>GitHub</a></dd>
          </>
        )}
        {publications.length > 0 && (
          <>
            <dt>Publications</dt>
            <dd>
              <ul class="publication-list">
                {publications.map((pub) => (
                  <li>
                    {pub.url ? <a href={pub.url}>{pub.title}</a> : pub.title}
                    <span class="pub-venue">{pub.venue}, {pub.date}</span>
                  </li>
                ))}
              </ul>
            </dd>
          </>
        )}
        {relatedProjects.length > 0 && (
          <>
            <dt>Related</dt>
            <dd>
              {relatedProjects.map((p, i) => (
                <>
                  {i > 0 && ", "}
                  <a href={`/projects/${p.slug}/`}>{p.title}</a>
                </>
              ))}
            </dd>
          </>
        )}
      </dl>
    </header>
    <div class="project-content">
      {hero && (
        <figure class="project-photo">
          <Image
            src={hero}
            alt={heroAlt || title}
            widths={[800, 1200, 1600]}
            sizes="(max-width: 768px) 100vw, 800px"
          />
        </figure>
      )}
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .project {
    max-width: var(--width-content);
    margin: 0 auto;
  }

  .project-hero {
    position: relative;
    display: grid;
    place-items: center;
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-bottom: var(--space-xl);
    aspect-ratio: 3 / 1;
    max-height: 40vh;
  }

  .hero-title {
    position: relative;
    color: var(--color-fg);
    -webkit-text-stroke: 5px var(--color-bg);
    paint-order: stroke fill;
  }

  .project-header {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .project-meta {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-xs) var(--space-lg);
    margin-top: var(--space-md);
    font-size: 0.9375rem;
  }

  .project-meta dt {
    color: var(--color-fg-muted);
  }

  .project-meta dd {
    margin: 0;
  }

  .project-meta a {
    color: var(--color-accent);
  }

  .publication-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .publication-list li + li {
    margin-top: var(--space-xs);
  }

  .pub-venue {
    display: block;
    color: var(--color-fg-muted);
    font-size: 0.875rem;
  }

  .project-content {
    line-height: 1.8;
  }

  .project-content :global(h2) {
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
  }

  .project-content :global(p) {
    margin-bottom: var(--space-md);
  }

  .project-content :global(img) {
    border-radius: 0.5rem;
    margin: var(--space-lg) 0;
  }

  .project-photo {
    margin: 0 0 var(--space-xl);
  }

  .project-photo :global(img) {
    width: 100%;
    border-radius: 0.5rem;
  }
</style>
