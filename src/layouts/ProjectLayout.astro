---
import type { ImageMetadata } from "astro";
import ContentLayout from "astro-theme-anu/layouts/ContentLayout.astro";
import { siteConfig } from "../site-config";

interface Publication {
  title: string;
  venue: string;
  date: string;
  url?: string;
}

interface Props {
  title: string;
  description: string;
  creators: string[];
  materials?: string;
  date: string;
  hero?: ImageMetadata;
  heroAlt?: string;
  url?: string;
  github?: string;
  publications: Publication[];
  relatedProjects: { slug: string; title: string }[];
}

const {
  title,
  description,
  creators,
  materials,
  date,
  hero,
  heroAlt,
  url,
  github,
  publications,
  relatedProjects,
} = Astro.props;

const formattedDate = new Date(date).toLocaleDateString("en-AU", {
  year: "numeric",
  month: "long",
});
---

<ContentLayout
  title={title}
  description={description}
  heroImage={hero}
  heroImageAlt={heroAlt ?? title}
  {...siteConfig}
>
  <dl class="project-meta">
    {creators.length > 0 && (
      <>
        <dt>Creators</dt>
        <dd>{creators.join(", ")}</dd>
      </>
    )}
    {materials && (
      <>
        <dt>Materials</dt>
        <dd>{materials}</dd>
      </>
    )}
    <dt>Launched</dt>
    <dd><time datetime={date}>{formattedDate}</time></dd>
    {url && (
      <>
        <dt>Link</dt>
        <dd><a href={url}>{url}</a></dd>
      </>
    )}
    {github && (
      <>
        <dt>Source</dt>
        <dd><a href={github}>GitHub</a></dd>
      </>
    )}
    {publications.length > 0 && (
      <>
        <dt>Publications</dt>
        <dd>
          <ul class="publication-list">
            {publications.map((pub) => (
              <li>
                {pub.url ? <a href={pub.url}>{pub.title}</a> : pub.title}
                <span class="pub-venue">{pub.venue}, {pub.date}</span>
              </li>
            ))}
          </ul>
        </dd>
      </>
    )}
    {relatedProjects.length > 0 && (
      <>
        <dt>Related</dt>
        <dd>
          {relatedProjects.map((p, i) => (
            <>
              {i > 0 && ", "}
              <a href={`/projects/${p.slug}/`}>{p.title}</a>
            </>
          ))}
        </dd>
      </>
    )}
  </dl>
  <slot />
</ContentLayout>

<style>
  .project-meta {
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.25rem 1.5rem;
    margin: 0 0 2rem;
    font-size: 0.9375rem;
  }

  .project-meta dt {
    font-weight: 600;
  }

  .project-meta dd {
    margin: 0;
  }

  .publication-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .publication-list li + li {
    margin-top: 0.5rem;
  }

  .pub-venue {
    display: block;
    font-size: 0.875rem;
    opacity: 0.75;
  }
</style>
