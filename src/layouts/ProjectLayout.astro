---
import { Image } from "astro:assets";
import BaseLayout from "./BaseLayout.astro";
import LissajousImage from "../components/LissajousImage.svelte";

interface Props {
  title: string;
  description: string;
  date: string;
  hero?: ImageMetadata;
  heroAlt?: string;
  slug?: string;
}

const { title, description, date, hero, heroAlt, slug } = Astro.props;
const formattedDate = new Date(date).toLocaleDateString("en-AU", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={title} description={description} image={hero?.src}>
  <article class="project">
    {slug && (
      <div class="project-hero" style={slug ? `view-transition-name: hero-${slug}` : undefined}>
        <LissajousImage client:only="svelte" src={`/lissajous/${slug}.json`} />
      </div>
    )}
    <header class="project-header">
      <h1 class="glow-strong">{title}</h1>
      <p class="project-meta">
        <time datetime={date}>{formattedDate}</time>
      </p>
    </header>
    <div class="project-content">
      {hero && (
        <figure class="project-photo">
          <Image
            src={hero}
            alt={heroAlt || title}
            widths={[800, 1200, 1600]}
            sizes="(max-width: 768px) 100vw, 800px"
          />
        </figure>
      )}
      <slot />
    </div>
  </article>
</BaseLayout>

<style>
  .project {
    max-width: var(--width-content);
    margin: 0 auto;
  }

  .project-hero {
    width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-bottom: var(--space-xl);
    aspect-ratio: 3 / 1;
    max-height: 40vh;
  }

  .project-header {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-lg);
    border-bottom: 1px solid var(--color-border);
  }

  .project-meta {
    color: var(--color-fg-muted);
    margin-top: var(--space-sm);
  }

  .project-content {
    line-height: 1.8;
  }

  .project-content :global(h2) {
    margin-top: var(--space-xl);
    margin-bottom: var(--space-md);
  }

  .project-content :global(p) {
    margin-bottom: var(--space-md);
  }

  .project-content :global(img) {
    border-radius: 0.5rem;
    margin: var(--space-lg) 0;
  }

  .project-photo {
    margin: 0 0 var(--space-xl);
  }

  .project-photo :global(img) {
    width: 100%;
    border-radius: 0.5rem;
  }
</style>
